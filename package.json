{
  "name": "open-headers",
  "version": "3.5.0",
  "description": "Record your browser tab. Modify HTTP Traffic. Team Workspaces. Everything local.",
  "scripts": {
    "// Build //": "",
    "build": "npm run build:chrome && npm run build:firefox && npm run build:edge && npm run build:safari",
    "build:chrome": "BROWSER=chrome vite build",
    "build:firefox": "BROWSER=firefox vite build",
    "build:edge": "BROWSER=edge vite build",
    "build:safari": "BROWSER=safari vite build",
    "// Development //": "",
    "dev": "BROWSER=chrome vite build --watch",
    "dev:chrome": "BROWSER=chrome vite build --watch",
    "dev:firefox": "BROWSER=firefox vite build --watch",
    "dev:edge": "BROWSER=edge vite build --watch",
    "dev:safari": "BROWSER=safari vite build --watch",
    "// Safari //": "",
    "safari:convert": "mkdir -p manifests/safari/xcode_project && xcrun safari-web-extension-converter ./dist/safari --app-name \"Open Headers\" --bundle-identifier \"com.openheaders.safari\" --copy-resources --project-location .manifests/safari/xcode_project",
    "// Testing //": "",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "// E2E //": "",
    "test:e2e": "npx playwright test",
    "test:e2e:headed": "npx playwright test --headed",
    "// Type checking //": "",
    "typecheck": "tsc --noEmit",
    "// Release //": "",
    "postbuild": "npx tsx config/scripts/build-report.ts",
    "release": "npx tsx config/scripts/release.ts",
    "source-zip": "npx tsx config/scripts/source-zip.ts"
  },
  "dependencies": {
    "@ant-design/icons": "^5.2.6",
    "antd": "^5.13.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rrweb": "^2.0.0-alpha.18",
    "rrweb-player": "^2.0.0-alpha.18",
    "styled-components": "^6.1.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/react": "^16.3.2",
    "@types/archiver": "^7.0.0",
    "@types/chrome": "^0.1.38",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "archiver": "^5.3.2",
    "jsdom": "^29.0.1",
    "less": "^4.2.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "qs": "^6.14.1",
    "node-forge": "^1.3.2",
    "lodash": "^4.17.23"
  }
}
